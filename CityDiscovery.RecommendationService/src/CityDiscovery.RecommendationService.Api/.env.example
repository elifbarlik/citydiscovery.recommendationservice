# Bu dosyayı .env olarak kopyalayıp değerleri doldurun: cp .env.example .env

# --- Veritabanı ---
ConnectionStrings__DefaultConnection=Server=localhost;Database=Discovery_RecommendationDb;Trusted_Connection=True;TrustServerCertificate=True;

# --- JWT Authentication ---
Jwt__Key=<minimum-32-karakter-guclu-secret>
Jwt__Issuer=identity
Jwt__Audience=citydiscovery

# --- Embedding Provider ---
EmbeddingProvider__UseMock=true
EmbeddingProvider__Gemini__ApiKey=<gemini-api-key>
EmbeddingProvider__Gemini__Model=gemini-embedding-001
EmbeddingProvider__Gemini__Dimensions=384

# --- RabbitMQ ---
RabbitMQ__Host=rabbitmq://localhost
RabbitMQ__Username=guest
RabbitMQ__Password=guest

# --- ASP.NET Core ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5027
